# Frappe ERP
FRAPPE_BASE_URL=http://localhost:8000
FRAPPE_API_KEY=your_api_key_here
FRAPPE_API_SECRET=your_api_secret_here

# Telegram Bot
SHOW_DEV_TO_PUBLIC=false
TELEGRAM_BOT_TOKEN=your_bot_token_here
NGROK_AUTHTOKEN=your_ngrok_token_here
LOOV_IS_STAFF_PORTAL_URL=https://staff-focus.localhost

# Outline Wiki (для BFF)
OUTLINE_BASE_URL=https://wiki.loov.ru
OUTLINE_API_KEY=your_outline_api_key_here

# API Security
API_SECRET_KEY=your_api_secret_key_here
EXTERNAL_API_KEY=your_external_api_key_here
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://staff-focus.localhost

# Frontend API
VITE_API_BASE_URL=http://localhost:3000
VITE_API_SECRET_KEY=your_api_secret_key_here
VITE_TG_BOT_USERNAME=loovis_portal_dev_bot

# Server
PORT=3000
HOST=staff-focus.localhost

# Development
NODE_ENV=development

# Показывать ли dev-версию (ngrok) публично в Telegram (только в development режиме)
SHOW_DEV_TO_PUBLIC=false

# Tracker API (для Dashboard BFF)
TRACKER_API_URL=https://tracker.loov.ru
TRACKER_API_TOKEN=your_tracker_api_token_here 

# OpenSearch Logging
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin
OPENSEARCH_BACKEND_INDEX_PREFIX=staff-focus-app
OPENSEARCH_SSL_VERIFY=false
OPENSEARCH_SEND_LOGS=true

# Logging Level (debug, info, warn, error)
LOG_LEVEL=info

# PostgreSQL (optional — falls back to JSON files if not configured)
DATABASE_URL=postgresql://staff_focus:your_password_here@localhost:5432/staff_focus
POSTGRES_USER=staff_focus
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=staff_focus

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password_here

# Org Structure Data Source
# 'frappe' — use Frappe API (default, no changes)
# 'postgres' — use own PostgreSQL database
# 'dual' — PostgreSQL primary + Frappe background comparison
ORG_DATA_SOURCE=postgres

# Frappe Sync (transition period)
FRAPPE_SYNC_ENABLED=false
FRAPPE_SYNC_INTERVAL_HOURS=6
